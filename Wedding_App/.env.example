# GOOGLE OAUTH2 CONFIGURATION
# Ottieni credenziali da: https://console.cloud.google.com
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

