# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT & SECURITY
# Genera una stringa casuale lunga per SECRET_KEY in produzione
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SECRET_KEY=your-super-secret-key-change-in-production-12345!@#$%

# Admin users (separati da virgola)
ADMIN_EMAILS=admin@example.com,organizer@example.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL CONFIGURATION (SMTP)
# Opzioni gratuite:
# 1. Gmail - Usa app-specific password (https://myaccount.google.com/apppasswords)
# 2. Brevo (Sendinblue) - 300 email/giorno gratis (https://www.brevo.com)
# 3. Mailgun - 100 email/giorno gratis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Gmail (con app-specific password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Brevo/Sendinblue alternative (uncomment per usare)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-brevo-smtp-key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
